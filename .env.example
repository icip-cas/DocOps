# Copy this file to .env and fill in the credentials needed by your harness.

# Common Harbor settings.
HARBOR_PYTHON_BIN=.venv/bin/python
HARBOR_RUN_COUNT=1
HARBOR_N_CONCURRENT=1
DOCOPS_OUTPUT_ROOT=results

# OpenAI-compatible API settings used by DocumentTools, Terminus-2, and Codex.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Model defaults. Override these for your provider.
DOCOPS_DOCTOOLS_MODEL=openai/gpt-5.5
DOCOPS_TERMINUS2_MODEL=openai/gpt-5.5
DOCOPS_CODEX_MODEL=gpt-5.5

# Codex-specific settings.
CODEX_FORCE_API_KEY=1
CODEX_CONFIG_TOML_PATH=

# Claude Code settings.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
DOCOPS_CLAUDE_MODEL=claude-sonnet-4-6

# Optional harness controls.
HARBOR_DT_MAX_STEPS=12
HARBOR_DT_TEMPERATURE=0.0
HARBOR_DT_REASONING_EFFORT=high
HARBOR_T2_MAX_TURNS=200
HARBOR_T2_PARSER=json
HARBOR_T2_TEMPERATURE=0.2
HARBOR_T2_REASONING_EFFORT=high
HARBOR_T2_ENABLE_SUMMARIZE=true
